---
// Puedes cambiar los links aquí
const social = [
  {
    name: "",
    url: "https://www.tiktok.com/@jossmamani223/video/7644992525744606485?is_from_webapp=1&sender_device=pc&web_id=7614613690356581889",
    icon: "tiktok",
  },
  {
    name: "",
    url: "https://wa.me/51974357754",
    icon: "whatsapp",
  },
  {
    name: "",
    url: "https://www.facebook.com/joss.mamani.18",
    icon: "facebook",
  },
  {
    name: "",
    url: "https://www.instagram.com/jossmamani/",
    icon: "instagram",
  },
];
//hasta aqui
---

<footer class="footer">
  <p>tienda digital con miras para el futuro_xd</p>

  <div class="social-container">
    {
      social.map((item) => (
        <a
          class="social-btn"
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          {item.icon === "tiktok" && (
            <svg viewBox="0 0 24 24" class="icon">
              <path d="M12 2v10.2a4.2 4.2 0 1 0 3.6 4.15V10.6a6.7 6.7 0 0 0 4.4 1.6V8.8a4.7 4.7 0 0 1-3.2-1.4 4.7 4.7 0 0 1-1.4-3.4H12z" />
            </svg>
          )}

          {item.icon === "whatsapp" && (
            <svg viewBox="0 0 24 24" class="icon">
              <path d="M20.5 3.5A11 11 0 0 0 3.4 17.7L2 22l4.4-1.3A11 11 0 0 0 20.5 3.5z" />
            </svg>
          )}

          {item.icon === "facebook" && (
            <svg viewBox="0 0 24 24" class="icon">
              <path d="M13 22v-8h3l1-4h-4V7c0-1.1.4-2 2-2h2V1h-3c-3.3 0-5 2-5 5v4H7v4h3v8h3z" />
            </svg>
          )}

          {item.icon === "instagram" && (
            <svg viewBox="0 0 24 24" class="icon">
              <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5z" />
            </svg>
          )}

          <span>{item.name}</span>
        </a>
      ))
    }
  </div>
</footer>

<style>
  .footer {
    background: #111;
    color: white;
    text-align: center;
    padding: 1rem;
  }

  .social-container {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 20px;
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    font-weight: bold;
    transition: 0.3s;
  }

  /* ICONOS */
  .icon {
    width: 20px;
    height: 22px;
    fill: white;
  }

  /* COLORES */
  .social-btn:nth-child(1) {
    background: #000;
  } /* TikTok */
  .social-btn:nth-child(2) {
    background: #25d366;
  } /* WhatsApp */
  .social-btn:nth-child(3) {
    background: #1877f2;
  } /* Facebook */
  .social-btn:nth-child(4) {
    background: #e4405f;
  } /* Instagram */

  .social-btn:hover {
    transform: scale(1.05);
    opacity: 0.9;
  }
</style>
